# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# docs — la memoria académica (docs/memoria) SÍ se versiona; el resto de docs queda local
/docs/*
!/docs/memoria/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local operational notes (not versioned)
/DESPLIEGUE.local.md

# datos de siembra/demo (correos sintéticos — no se publican)
/scripts/demo-emails.*
/scripts/generate-demo-emails.mjs

# capturas locales sin uso en el repo
/landing.png
