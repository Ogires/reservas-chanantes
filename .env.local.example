# Plantilla de variables de entorno — Reservas Chanantes
# Copia este fichero a `.env.local` y rellena los valores. NO subas `.env.local` a Git.
# En producción, configura estas mismas variables en Vercel → Settings → Environment Variables.

# --- Supabase (PostgreSQL + Auth) ---
# Supabase → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (pagos + Connect) ---
# Stripe → Developers → API keys (usa sk_live_… en producción)
STRIPE_SECRET_KEY=
# Firma del webhook /api/webhooks/stripe (evento account.updated)
STRIPE_WEBHOOK_SECRET=
# Firma del webhook /api/webhooks/stripe-connect (evento checkout.session.completed)
STRIPE_CONNECT_WEBHOOK_SECRET=
# Stripe → Settings → Connect → OAuth (ca_…)
STRIPE_CONNECT_CLIENT_ID=

# --- Resend (correo transaccional) ---
# Resend → API Keys
RESEND_API_KEY=
# Dominio remitente verificado en Resend (p. ej. mail.tudominio.com)
RESEND_FROM_DOMAIN=

# --- Cron (recordatorios) ---
# Cadena aleatoria que generas tú; Vercel la envía como Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- URLs de la aplicación ---
# URL pública del sitio (en local: http://localhost:3000)
NEXT_PUBLIC_SITE_URL=
# URL base usada en las plantillas de correo (normalmente la misma que SITE_URL)
NEXT_PUBLIC_APP_URL=
